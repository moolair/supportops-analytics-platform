# PostgreSQL connection — copy to .env and adjust as needed.
# Used by docker-compose.yml and (later) the Go application + migrations.

POSTGRES_USER=supportops
POSTGRES_PASSWORD=supportops_dev_pw
POSTGRES_DB=supportops
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# Full DSN for the application / migration tooling.
DATABASE_URL=postgres://supportops:supportops_dev_pw@localhost:5432/supportops?sslmode=disable
